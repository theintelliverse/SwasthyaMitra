{
  "compilerOptions": {
    /* Output */
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./",
    "rootDir": "./",

    /* Emit */
    "declaration": false,
    "sourceMap": false,
    "removeComments": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,

    /* Type Checking */
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": false
  },
  "include": ["AI_model/appointment_predictor.ts"],
  "exclude": ["node_modules", "frontend"]
}
