VITE_API_URL=http://localhost:5000
# For production, set to your backend Vercel URL, e.g. https://your-backend.vercel.app

# Optional: Socket server URL. Leave empty in production if you don't host sockets separately.
VITE_SOCKET_URL=

# Firebase Web App config (required for phone OTP on /patient/login)
VITE_FB_PROJECT_ID=
VITE_FB_AUTH_DOMAIN=
VITE_FB_API_KEY=
VITE_FB_APP_ID=
VITE_FB_MESSAGING_SENDER_ID=
