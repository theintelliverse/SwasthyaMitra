VITE_API_URL=http://localhost:5000
# For production, set to your backend Railway URL, e.g. https://your-service.up.railway.app

# Optional: Socket server URL (must support Socket.IO). If your backend host supports sockets, set this to the same Railway URL.
VITE_SOCKET_URL=

# Firebase Web App config (required for phone OTP on /patient/login)
VITE_FB_PROJECT_ID=
VITE_FB_AUTH_DOMAIN=
VITE_FB_API_KEY=
VITE_FB_APP_ID=
VITE_FB_MESSAGING_SENDER_ID=
